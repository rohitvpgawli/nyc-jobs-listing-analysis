# Copy to `.env` in the repo root and fill in your key.
# cp .env.example .env

# GLM 5.2 via Z.ai (recommended — OpenAI-compatible chat completions API)
# Get a key at https://z.ai
ZAI_API_KEY=eb0f24d1c5c44aab9cedbe38e1b4606f.vfazL2f8upg9mbYv

# Alias accepted by the pipeline if you prefer this name:
# GLM_API_KEY=

# Optional overrides (defaults shown)
LLM_MODEL=glm-5.2
LLM_BASE_URL=https://api.z.ai/api/paas/v4

# If you use Z.ai's Coding Plan endpoint instead:
# LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4

# Legacy OpenAI-compatible providers still work:
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
